# ============================================
# YES Doubt-Resolution Platform — Environment
# Copy this file to .env and fill in values
# ============================================

# ---------- App ----------
APP_NAME=edtech-doubt-resolution
APP_ENV=development
APP_PORT=8000
DEBUG=true

# ---------- PostgreSQL ----------
POSTGRES_USER=edtech
POSTGRES_PASSWORD=edtech_secret
POSTGRES_DB=edtech_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://edtech:edtech_secret@postgres:5432/edtech_db

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- JWT / Auth ----------
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Payments ----------
# Platform charges (in paise: 500 = ₹5)
PLATFORM_CHARGE_PER_USER=500
PLATFORM_CHARGE_PER_USER_INDIVIDUAL=500
PLATFORM_CHARGE_PER_USER_GROUP=300
# Commission percentages
COMMISSION_PERCENT=20.0
COMMISSION_PERCENT_INDIVIDUAL=20.0
COMMISSION_PERCENT_GROUP=15.0
# Payment gateway selection: mock, razorpay, stripe
PAYMENT_GATEWAY=razorpay
PAYMENT_CURRENCY=INR
# Razorpay credentials (get from https://dashboard.razorpay.com/app/keys)
# Test: rzp_test_xxxxx | Live: rzp_live_xxxxx
PAYMENT_GATEWAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# KEEP SECRET - never expose to frontend!
PAYMENT_GATEWAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Webhook secret (from Dashboard → Settings → Webhooks)
PAYMENT_WEBHOOK_SECRET=webhook_secret_xxxxxxxxxxxx

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---------- Media Uploads ----------
# Base URL used when generating upload and media URLs
PUBLIC_BASE_URL=http://localhost:8000
# Expiry for upload sessions (seconds)
UPLOAD_URL_EXPIRES_SECONDS=900
# Maximum video upload size accepted by backend (MB)
MAX_VIDEO_UPLOAD_SIZE_MB=200

# ---------- S3 Uploads ----------
# Required bucket used for teacher demo videos
S3_BUCKET_NAME=
# AWS region for the bucket
S3_REGION=us-east-1
# Optional custom endpoint (e.g., MinIO / R2)
S3_ENDPOINT_URL=
# Optional public CDN/base URL for serving uploaded files
S3_PUBLIC_BASE_URL=
# If true, backend uploads objects with public-read ACL
S3_OBJECT_PUBLIC=true
# Optional static credentials (use IAM role in production when possible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---------- Jitsi Meet ----------
JITSI_APP_ID=edtech-doubt-resolution
JITSI_SECRET=change-me-to-a-jitsi-secret-in-production
JITSI_DOMAIN=meet.jitsi
JITSI_URL=https://127.0.0.1:8443
JITSI_HOST=127.0.0.1
JITSI_HTTPS_PORT=8443
JITSI_HTTP_PORT=8080

# ---------- Jitsi Internal ----------
JICOFO_AUTH_PASSWORD=jicofo_pass_123
JICOFO_COMPONENT_SECRET=jicofo_component_123
JVB_AUTH_PASSWORD=jvb_pass_123
JVB_PORT=10000
JVB_ADVERTISE_IPS=127.0.0.1

# ---------- Timezone ----------
TZ=UTC
