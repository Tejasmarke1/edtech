# ============================================
# YES Doubt-Resolution Platform — Environment
# Copy this file to .env and fill in values
# ============================================

# ---------- App ----------
APP_NAME=edtech-doubt-resolution
APP_ENV=development
APP_PORT=8000
DEBUG=true

# ---------- PostgreSQL ----------
POSTGRES_USER=edtech
POSTGRES_PASSWORD=edtech_secret
POSTGRES_DB=edtech_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://edtech:edtech_secret@postgres:5432/edtech_db

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- JWT / Auth ----------
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Payments ----------
PLATFORM_CHARGE_PER_USER=20
COMMISSION_PERCENT=10.0
PLATFORM_CHARGE_PER_USER_INDIVIDUAL=20
PLATFORM_CHARGE_PER_USER_GROUP=20
COMMISSION_PERCENT_INDIVIDUAL=10.0
COMMISSION_PERCENT_GROUP=10.0
PAYMENT_GATEWAY=mock
PAYMENT_CURRENCY=INR
PAYMENT_GATEWAY_KEY_ID=
PAYMENT_GATEWAY_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---------- Jitsi Meet ----------
JITSI_APP_ID=edtech-doubt-resolution
JITSI_SECRET=change-me-to-a-jitsi-secret-in-production
JITSI_DOMAIN=meet.jitsi
JITSI_URL=https://127.0.0.1:8443
JITSI_HOST=127.0.0.1
JITSI_HTTPS_PORT=8443
JITSI_HTTP_PORT=8080

# ---------- Jitsi Internal ----------
JICOFO_AUTH_PASSWORD=jicofo_pass_123
JICOFO_COMPONENT_SECRET=jicofo_component_123
JVB_AUTH_PASSWORD=jvb_pass_123
JVB_PORT=10000
JVB_ADVERTISE_IPS=127.0.0.1

# ---------- Timezone ----------
TZ=UTC
