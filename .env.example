# ============================================
# YES Doubt-Resolution Platform — Environment
# Copy this file to .env and fill in values
# ============================================

# ---------- App ----------
APP_NAME=edtech-doubt-resolution
APP_ENV=development
APP_PORT=8000
DEBUG=true

# ---------- PostgreSQL ----------
POSTGRES_USER=edtech
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=edtech_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://edtech:CHANGE_ME@postgres:5432/edtech_db

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- JWT / Auth ----------
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
